#!/usr/bin/env bash
# Molt chain tracker: a consistent session name (base_N) + color across a whole molt chain.
# molt-spawn reads this to name and color each spawned session (<base>_N, same color as the chain).
#   molt-chain            -> advance the chain (or start it, base "molt") and print "<name>\t<color>"
#   molt-chain <base>     -> same, but use <base> when starting a fresh chain
#   molt-chain reset      -> forget the chain (next call starts a new one)
#   molt-chain reset <b>  -> forget it and start fresh at <b>_1
if [ "${JUNK_DRAWER_RUNTIME:-}" = kimi ] || [ -n "${KIMI_PLUGIN_ROOT:-}" ]; then
    cfg="${KIMI_CODE_HOME:-$HOME/.kimi-code}/junk-drawer"
elif [ "${JUNK_DRAWER_RUNTIME:-}" = codex ] || [ -n "${PLUGIN_ROOT:-}" ]; then
    cfg="${CODEX_HOME:-$HOME/.codex}/junk-drawer"
else
    cfg="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
fi
mkdir -p "$cfg"
file="$cfg/molt-chain"
colors=(red blue green yellow purple orange pink cyan)
if [ "${1:-}" = reset ]; then
    rm -f "$file"; shift
    [ $# -gt 0 ] || exit 0   # bare `reset` just forgets the chain; don't recreate it
fi
if [ -f "$file" ]; then
    IFS=$'\t' read -r base color n < "$file"
    n=$((n + 1))
else
    base="${1:-molt}"
    color="${colors[$((RANDOM % ${#colors[@]}))]}"
    n=1
fi
printf '%s\t%s\t%s\n' "$base" "$color" "$n" > "$file"
printf '%s_%s\t%s\n' "$base" "$n" "$color"
