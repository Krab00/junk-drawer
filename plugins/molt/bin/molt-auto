#!/usr/bin/env bash
# Toggle auto-molt: Claude forces continuation; Codex emits a Stop-hook warning at the limit.
# State lives in ~/.claude, read fresh each turn.
#   molt-auto on | off | status
#   molt-auto limit <tokens>   -> defaults: Codex 200000, Claude Code 300000
if [ "${JUNK_DRAWER_RUNTIME:-}" = kimi ] || [ -n "${KIMI_PLUGIN_ROOT:-}" ]; then
    cfg="${KIMI_CODE_HOME:-$HOME/.kimi-code}/junk-drawer"
elif [ "${JUNK_DRAWER_RUNTIME:-}" = codex ] || [ -n "${PLUGIN_ROOT:-}" ]; then
    cfg="${CODEX_HOME:-$HOME/.codex}/junk-drawer"
else
    cfg="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
fi
mkdir -p "$cfg"
flag="$cfg/molt-auto"; limf="$cfg/molt-limit"
if [ "${JUNK_DRAWER_RUNTIME:-}" = kimi ] || [ -n "${KIMI_PLUGIN_ROOT:-}" ]; then def=200000
elif [ "${JUNK_DRAWER_RUNTIME:-}" = codex ] || [ -n "${PLUGIN_ROOT:-}" ]; then def=200000; else def=300000; fi
lim() { cat "$limf" 2>/dev/null || echo "$def"; }

case "${1:-status}" in
    on)  : > "$flag"; echo "auto-molt ON @ $(lim) tokens - the Stop hook will request a continuation when context crosses it." ;;
    off) rm -f "$flag"; echo "auto-molt OFF." ;;
    limit)
        v="${2:-}"; mult=1
        case "$v" in *[kK]) mult=1000; v="${v%?}" ;; *[mM]) mult=1000000; v="${v%?}" ;; esac
        case "$v" in ''|*[!0-9]*) echo "usage: molt-auto limit <tokens>" >&2; exit 1 ;; esac
        echo $((v * mult)) > "$limf"; echo "auto-molt limit = $(lim) tokens." ;;
    *)   [ -f "$flag" ] && echo "auto-molt: ON @ $(lim) tokens" || echo "auto-molt: OFF (limit $(lim))" ;;
esac
