#!/usr/bin/env bash
# Stop hook: Claude blocks and requests a molt; Codex warns without preventing task completion.
# Opt-in (needs ~/.claude/molt-auto). Self-contained: only jq. Reads transcript_path from stdin.
if [ -n "${KIMI_PLUGIN_ROOT:-}" ]; then
    cfg="${KIMI_CODE_HOME:-$HOME/.kimi-code}/junk-drawer"
elif [ -n "${PLUGIN_ROOT:-}" ]; then
    cfg="${CODEX_HOME:-$HOME/.codex}/junk-drawer"
else
    cfg="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
fi
[ -f "$cfg/molt-auto" ] || exit 0

input=$(cat)
# Claude loop guard: if continuation was already forced this stop-episode, let it stop now.
printf '%s' "$input" | jq -e '.stop_hook_active == true' >/dev/null 2>&1 && exit 0

tp=$(printf '%s' "$input" | jq -r '.transcript_path // empty' 2>/dev/null)
if [ -z "$tp" ] && [ -n "${KIMI_PLUGIN_ROOT:-}" ]; then
    # Kimi hooks pass session_id/cwd, not transcript_path; resolve the live wire.jsonl ourselves.
    sid=$(printf '%s' "$input" | jq -r '.session_id // empty' 2>/dev/null)
    tp=$(ls -t "${KIMI_CODE_HOME:-$HOME/.kimi-code}/sessions"/*/"${sid:-__none__}"/agents/main/wire.jsonl 2>/dev/null | head -1)
fi
[ -n "$tp" ] && [ -f "$tp" ] || exit 0

if [ -n "${KIMI_PLUGIN_ROOT:-}" ]; then def=200000
elif [ -n "${PLUGIN_ROOT:-}" ]; then def=200000; else def=300000; fi
lim=$(cat "$cfg/molt-limit" 2>/dev/null); lim=${lim:-$def}
case "$lim" in ''|*[!0-9]*) lim=$def ;; esac

# ponytail: inline token count — plugin bin/ isn't on a hook's PATH. Keep in sync with ctx-tokens.
ctx=$(jq -rs '
    [ .[] | select(.type == "event_msg" and .payload.type == "token_count") ][-1]
    | .payload.info.last_token_usage.input_tokens // empty
' "$tp" 2>/dev/null)
if [ -z "$ctx" ]; then
    ctx=$(jq -rs '
        [ .[] | select(.type == "context.append_loop_event" and .event.type == "step.end" and .event.usage) ][-1]
        | if . == null then empty
          else .event.usage as $u | (($u.inputOther // 0) + ($u.inputCacheRead // 0) + ($u.inputCacheCreation // 0))
          end
    ' "$tp" 2>/dev/null)
fi
if [ -z "$ctx" ]; then
    ctx=$(grep '"usage"' "$tp" 2>/dev/null | tail -n1 | jq -r '
        (.message.usage // .usage) as $u
        | (($u.input_tokens // 0) + ($u.cache_creation_input_tokens // 0) + ($u.cache_read_input_tokens // 0))' 2>/dev/null)
fi
case "$ctx" in ''|*[!0-9]*) exit 0 ;; esac
[ "$ctx" -ge "$lim" ] 2>/dev/null || exit 0

# Codex uses structured hook output. Kimi and Claude Code use exit-2 with an instruction on stderr.
if [ -n "${PLUGIN_ROOT:-}" ]; then
    msg="Molt recommended: context is ${ctx} tokens (limit ${lim}). Invoke the molt skill to save a continuation before starting a fresh task."
    jq -cn --arg msg "$msg" '{continue:true, systemMessage:$msg}'
    exit 0
fi
if [ -n "${KIMI_PLUGIN_ROOT:-}" ]; then
    echo "MOLT NOW - context is ${ctx} tokens (limit ${lim}). Invoke the molt skill: write a thorough handoff via molt-path, then tell the user to continue in a fresh session. Do NOT continue the old task in this session." >&2
    exit 2
fi
echo "MOLT NOW - context is ${ctx} tokens (limit ${lim}). Before you stop, shed into a fresh session:
1. Run \`molt-path\` to get the handoff file path (line 1) and short id (line 2).
2. Write a thorough handoff to that path (what we're doing, state, done, next, key paths, gotchas).
3. Run \`molt-spawn <handoff-path> <project-dir>\` — it spawns a fresh claude session, seeds the handoff, and turns on remote control.
4. Tell the user you molted (give the new session's name), then stop. Do NOT continue the old task in this session." >&2
exit 2
