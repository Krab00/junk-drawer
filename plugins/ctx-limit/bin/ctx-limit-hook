#!/usr/bin/env bash
# UserPromptSubmit hook: enforce the session context-size limit.
# Off unless ~/.claude/ctx-limit-threshold holds a number. Past it, apply the configured action:
#   block (default) -> exit 2, reject the prompt (stderr shown to user)
#   warn            -> stdout added to context, prompt proceeds
#   cmd             -> run ~/.claude/ctx-limit-cmd, prompt proceeds
# Self-contained: needs only jq. Reads transcript_path from the hook's JSON stdin.
cfg="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
thrf="$cfg/ctx-limit-threshold"
[ -f "$thrf" ] || exit 0
thr=$(cat "$thrf"); case "$thr" in ''|*[!0-9]*) exit 0 ;; esac

input=$(cat)
# ponytail: escape hatches — let control/handoff commands through even over the limit, else block
# could lock you out (can't /ctx-limit off or /molt to recover). Slash commands arrive as .prompt.
case "$(printf '%s' "$input" | jq -r '.prompt // empty' 2>/dev/null)" in
    /ctx-limit*|/molt*|/handoff*|/handon*|/clear*) exit 0 ;;
esac
tp=$(printf '%s' "$input" | jq -r '.transcript_path // empty' 2>/dev/null)
[ -n "$tp" ] && [ -f "$tp" ] || exit 0
# ponytail: inline the token count — plugin bin/ is NOT on a hook's PATH, so we can't call
# ctx-tokens here. jq over the transcript is all it needs. Keep in sync with ctx-tokens' math.
ctx=$(grep '"usage"' "$tp" 2>/dev/null | tail -n1 | jq -r '
    (.message.usage // .usage) as $u
    | (($u.input_tokens // 0) + ($u.cache_creation_input_tokens // 0) + ($u.cache_read_input_tokens // 0))' 2>/dev/null)
case "$ctx" in ''|*[!0-9]*) exit 0 ;; esac
[ "$ctx" -ge "$thr" ] 2>/dev/null || exit 0

action=$(cat "$cfg/ctx-limit-action" 2>/dev/null); action=${action:-block}
case "$action" in
    warn)
        echo "⚠️ ctx-limit: context is ${ctx} tokens (limit ${thr}). Consider /clear or /molt."
        ;;
    cmd)
        c=$(cat "$cfg/ctx-limit-cmd" 2>/dev/null)
        [ -n "$c" ] && CTX_TOKENS="$ctx" CTX_LIMIT="$thr" bash -c "$c" >/dev/null 2>&1
        ;;
    *)
        echo "ctx-limit reached: ${ctx} ≥ ${thr} tokens. Run /molt to continue in a fresh session (or /clear, or /ctx-limit off)." >&2
        exit 2
        ;;
esac
exit 0
