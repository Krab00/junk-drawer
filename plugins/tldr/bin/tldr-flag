#!/usr/bin/env bash
# Toggle global TL;DR mode by presence of a flag file. Read by the UserPromptSubmit hook each turn.
#   tldr-flag on | off | status
if [ "${JUNK_DRAWER_RUNTIME:-}" = kimi ] || [ -n "${KIMI_PLUGIN_ROOT:-}" ]; then
    cfg="${KIMI_CODE_HOME:-$HOME/.kimi-code}/junk-drawer"
elif [ "${JUNK_DRAWER_RUNTIME:-}" = codex ] || [ -n "${PLUGIN_ROOT:-}" ]; then
    cfg="${CODEX_HOME:-$HOME/.codex}/junk-drawer"
else
    cfg="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
fi
mkdir -p "$cfg"
flag="$cfg/tldr-on"
case "${1:-status}" in
    on)  : > "$flag"; echo "TL;DR mode ON (all sessions with the plugin). Use tldr off to stop." ;;
    off) rm -f "$flag"; echo "TL;DR mode OFF." ;;
    *)   [ -f "$flag" ] && echo "TL;DR mode: ON" || echo "TL;DR mode: OFF" ;;
esac
