#!/usr/bin/env bash
# Build a live catalog from sibling manifests in a checkout or installed marketplace cache.
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
runtime="${JUNK_DRAWER_RUNTIME:-claude}"
manifests=()

if [ "$runtime" = codex ]; then
    manifest_dir=.codex-plugin
    cache_mkt="${CODEX_HOME:-$HOME/.codex}/plugins/cache/junk-drawer"
    heading="junk-drawer - Codex plugin marketplace (Krab00)"
    install="install: codex plugin add <name>@junk-drawer"
elif [ "$runtime" = kimi ]; then
    manifest_dir=.kimi-plugin
    cache_mkt="${KIMI_CODE_HOME:-$HOME/.kimi-code}/plugins/managed"
    heading="junk-drawer - Kimi Code plugin marketplace (Krab00)"
    install="install: /plugins install <name> (see kimi-marketplace.json)"
else
    manifest_dir=.claude-plugin
    cache_mkt="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/plugins/cache/junk-drawer"
    heading="junk-drawer - Claude Code plugin marketplace (Krab00)"
    install="install: /plugin install <name>@junk-drawer"
fi
[ -d "$cache_mkt" ] && cache_mkt="$(cd "$cache_mkt" && pwd)"

if [ "${here#"$cache_mkt"/}" != "$here" ]; then
    for namedir in "$cache_mkt"/*/; do
        [ -d "$namedir" ] || continue
        if [ "$runtime" = kimi ]; then
            # Kimi keeps a flat managed copy per plugin id: managed/<id>/.kimi-plugin/plugin.json
            manifest="${namedir}${manifest_dir}/plugin.json"
            [ -f "$manifest" ] && manifests+=("$manifest")
        else
            latest="$(ls -d "$namedir"*/ 2>/dev/null | sort | tail -1 || true)"
            manifest="${latest}${manifest_dir}/plugin.json"
            [ -n "$latest" ] && [ -f "$manifest" ] && manifests+=("$manifest")
        fi
    done
else
    plugins_root="$(cd "$here/../.." && pwd)"
    for manifest in "$plugins_root"/*/"$manifest_dir"/plugin.json; do
        [ -e "$manifest" ] && manifests+=("$manifest")
    done
fi

printf '%s\n%s\n\n' "$heading" "$install"
[ ${#manifests[@]} -gt 0 ] || { printf '(no plugins found)\n'; exit 0; }

for manifest in "${manifests[@]}"; do
    dir="$(dirname "$(dirname "$manifest")")"
    name="$(jq -r '.name' "$manifest")"
    ver="$(jq -r '.version // "?"' "$manifest")"
    desc="$(jq -r '.description // ""' "$manifest")"
    printf '%s  v%s\n  %s\n' "$name" "$ver" "$desc"

    found=0
    for skill in "$dir"/skills/*/SKILL.md; do
        [ -e "$skill" ] || continue
        found=1
        skill_name="$(awk -F': *' '$1 == "name" { print $2; exit }' "$skill")"
        skill_desc="$(awk -F': *' '$1 == "description" { sub(/^description: */, ""); print; exit }' "$skill")"
        skill_name="${skill_name:-$(basename "$(dirname "$skill")")}"
        if [ "$runtime" = kimi ]; then
            printf '    /skill:%s\n        %s\n' "$skill_name" "$skill_desc"
        else
            printf '    $%s\n        %s\n' "$skill_name" "$skill_desc"
        fi
    done

    if [ "$runtime" != codex ] && [ "$runtime" != kimi ]; then
        for cmd in "$dir"/commands/*.md; do
            [ -e "$cmd" ] || continue
            found=1
            fm="$(awk '/^---[[:space:]]*$/{n++; next} n==1{print}' "$cmd")"
            hint="$(printf '%s\n' "$fm" | sed -n 's/^argument-hint:[[:space:]]*//p' | tr -d '"')"
            cdesc="$(printf '%s\n' "$fm" | sed -n 's/^description:[[:space:]]*//p')"
            cname="/$name:$(basename "$cmd" .md)"
            [ -n "$hint" ] && cname="$cname $hint"
            printf '    %s\n        %s\n' "$cname" "$cdesc"
        done
    fi

    [ "$found" -eq 0 ] && printf '    (no workflows)\n'
    printf '\n'
done
